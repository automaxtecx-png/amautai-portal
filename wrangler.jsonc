/**
 * Cloudflare Workers — Static Assets only (no Worker code).
 * Sirve el HTML/CSS/JS de la raíz del repo como un sitio estático.
 *
 * Docs: https://developers.cloudflare.com/workers/static-assets/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "amautai-portal",
  "compatibility_date": "2026-05-22",
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
